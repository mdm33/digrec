- context_bar do
  .breadcrumbs
    != breadcrumbs ['Contents', sources_path], @source_division.source, 'New'

= semantic_form_for @source_division do |form|
  != form.input :id, :label => "Insert before", :as => :select, :collection => SourceDivision.where("source_id = ?",@source_division.source.id).order(:position)
  != form.input :title, :required => true
  != form.input :presentation_before, :required => false, :label => 'Presentation text before source division'
  != form.input :presentation_after, :required => false, :label => 'Presentation text after source division'
  != form.input :source, :as => :hidden, :input_html => {:value => @source_division.source.id}
  != form.submit "Create"
